{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@temp-project-angular-admin-portal/ui": ["./ui/src/index.ts"],
      "@temp-project-angular-admin-portal/ui/*": ["./ui/src/lib/*"],
      "@temp-project-angular-admin-portal/core/*": ["./ui/src/lib/core/*"],
      "@ui": ["./ui/src/index.ts"],
      "@amplify-schema": ["./amplify/data/resource.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}